# =====================================================================
# LeaveFlow - sablon variabile de mediu
# Copiaza acest fisier in `.env` (acelasi folder cu manage.py) si
# completeaza valorile reale. NU comita niciodata fisierul .env in git!
# =====================================================================

# --- Django ---
DJANGO_SECRET_KEY=schimba-cu-o-cheie-lunga-si-aleatoare
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Pe Render: DJANGO_CSRF_TRUSTED_ORIGINS=https://leaveflow.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Baza de date ---
# Local poti lasa gol -> se foloseste SQLite (db.sqlite3).
# Pentru PostgreSQL local: postgres://user:parola@localhost:5432/leaveflow
# Pe Render: pune valoarea Internal Database URL din panoul Postgres.
DATABASE_URL=
DATABASE_SSL=False

# --- Cloudinary (semnaturi & atasamente) ---
# Le iei din Cloudinary Dashboard -> Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Resend (email) ---
# Cheie API din https://resend.com/api-keys
# Daca lasi gol, mailurile se vor afisa doar in consola.
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=LeaveFlow <onboarding@resend.dev>
