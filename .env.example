# Copiaza acest fisier in `.env` si completeaza valorile.
# NU comita `.env` in git.

# Django
DJANGO_SECRET_KEY=schimba-cu-o-cheie-lunga-si-aleatoare
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
